# --- NEBULYZE PRODUCTION ENVIRONMENT ---

# Telegram Bot configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Supabase / PostgreSQL configuration
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:your_password@db.your_project_ref.supabase.co:5432/postgres

# Redis configuration (internal for Docker Compose)
REDIS_URL=redis://redis:6379/0

# Frontend configuration
# Use the public IP or domain of your Oracle VPS
NEXT_PUBLIC_API_URL=http://your_vps_ip:8000/api/v1

# Security Note: 
# Ensure port 8000 (API) and 3000 (Web) are open in Oracle Cloud Ingress Rules.
# Redis (6379) and Postgres (5432) do NOT need to be exposed to the public.
